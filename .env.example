# Copie para .env na raiz do projeto e preencha.

# Google Cloud Console → APIs e serviços → Credenciais → ID do cliente OAuth 2.0 (aplicativo Web)
# Origens JavaScript autorizadas: http://localhost:5173 (tem que ser EXATAMENTE esta URL+porta;
# se o front rodar em outra porta, o Google bloqueia com origin_mismatch)
#
# OBRIGATÓRIO: GOOGLE_CLIENT_ID e VITE_GOOGLE_CLIENT_ID devem ser a MESMA string (o mesmo ID .apps.googleusercontent.com).
# Se forem diferentes, o login falha na validação do token no servidor (não é erro de porta).
GOOGLE_CLIENT_ID=seu-id.apps.googleusercontent.com

# Mesmo valor do GOOGLE_CLIENT_ID (exposto ao front pelo Vite — use só o ID público do cliente Web)
VITE_GOOGLE_CLIENT_ID=seu-id.apps.googleusercontent.com

# Produção (ex.: front na Vercel, API em outro host): URL da API SEM barra no final.
# Em dev, deixe vazio para usar o proxy do Vite (localhost:3001).
# VITE_API_BASE_URL=https://sua-api.railway.app

# String longa e aleatória para assinar o cookie de sessão
SESSION_SECRET=gere-uma-string-longa-segura

# Origem do front (CORS + cookie) — alinhe com a origem autorizada no Google e com a porta do Vite (5173)
CLIENT_ORIGIN=http://localhost:5173

# Front e API em domínios diferentes (ex.: Vercel + Railway): ative para sessão funcionar no browser.
# TRUST_CROSS_SITE_SESSION=1

# =============================================================================
# FINANCEIRO (Administrador)
# =============================================================================
# Defina quais e-mails podem acessar a área /admin.
# Exemplo: ADMIN_EMAILS=financeiro@pxdata.ai,mayco@pxdata.ai
ADMIN_EMAILS=
